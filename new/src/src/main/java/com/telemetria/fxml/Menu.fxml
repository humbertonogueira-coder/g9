<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="549.0" prefWidth="682.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="MenuController">

    <children>
      <ImageView fitHeight="725.0" fitWidth="1014.0" layoutX="-172.0" layoutY="-6.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@imagens/highway-7213206_1280.jpg" />
         </image>
      </ImageView>
      
        <Label layoutX="283.0" layoutY="511.0" text="Login realizado com sucesso!" textFill="WHITE">
         <font>
            <Font size="16.0" />
         </font></Label>
         
      <Label fx:id="labelBoasVindas" layoutX="291.0" layoutY="35.0" text="Seja bem-vindo" textFill="WHITE">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      
      <Button fx:id="btnModulo" layoutX="138.0" layoutY="144.0" mnemonicParsing="false" onAction="#acessarModulo" prefHeight="57.0" prefWidth="268.0" text="Acessar Módulo do Sistema (Telemetria/Gestão)" />

       <Button fx:id="btnAlterar" layoutX="138.0" layoutY="221.0" mnemonicParsing="false" onAction="#alterarDados" prefHeight="57.0" prefWidth="183.0" text="Alterar meu nome" />

        <Button fx:id="btnExcluir" layoutX="142.0" layoutY="379.0" mnemonicParsing="false" onAction="#excluirConta" prefHeight="57.0" prefWidth="175.0" text="Excluir Minha Conta" />

        <Button fx:id="btnLogout" layoutX="142.0" layoutY="460.0" mnemonicParsing="false" onAction="#logout" prefHeight="51.0" prefWidth="175.0" text="Fazer Logout (Sair)" />
        
      <Button layoutX="138.0" layoutY="291.0" mnemonicParsing="false" onAction="#abrirAlterarSenha" prefHeight="64.0" prefWidth="183.0" text="Alterar minha senha" />
    </children>

</AnchorPane>