<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" prefWidth="350.0" prefHeight="200.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="NomeAlterarController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label text="Alterar Nome do Usuário">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>
        
        <VBox spacing="5.0">
            <children>
                <Label text="Digite o NOVO Nome:" />
                <TextField fx:id="txtNovoNome" promptText="Novo nome completo" />
            </children>
        </VBox>
        
        <Button fx:id="btnConfirmar" onAction="#confirmarAlteracao" prefHeight="35.0" prefWidth="150.0" text="Confirmar Salvar" />
    </children>
</VBox>