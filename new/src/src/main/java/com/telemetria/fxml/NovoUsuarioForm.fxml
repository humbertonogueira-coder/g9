<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="12.0" prefWidth="350.0" prefHeight="350.0" 
      style="-fx-background-color: #2c3e50;" 
      xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="NovoUsuarioFormController">
    <padding>
        <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
    </padding>
    <children>
        <Label text="Adicionar Novo Usuário" textFill="WHITE">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>
        
        <VBox spacing="3.0">
            <children>
                <Label text="Nome Completo:" textFill="#ecf0f1" />
                <TextField fx:id="txtNome" />
            </children>
        </VBox>
        
        <VBox spacing="3.0">
            <children>
                <Label text="Login de Acesso:" textFill="#ecf0f1" />
                <TextField fx:id="txtLogin" promptText="Ex: joao.silva" />
            </children>
        </VBox>

        <VBox spacing="3.0">
            <children>
                <Label text="Senha Inicial:" textFill="#ecf0f1" />
                <PasswordField fx:id="txtSenha" />
            </children>
        </VBox>

        <VBox spacing="3.0">
            <children>
                <Label text="Perfil / Cargo:" textFill="#ecf0f1" />
                <ComboBox fx:id="comboPerfil" prefWidth="300.0" />
            </children>
        </VBox>
        
        <Button fx:id="btnSalvar" onAction="#salvarUsuario" prefHeight="35.0" prefWidth="150.0" 
                style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold;" 
                text="Salvar Credenciais" />
    </children>
</VBox>