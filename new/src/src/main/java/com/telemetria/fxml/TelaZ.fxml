<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="525.0" prefWidth="738.0" spacing="20.0" style="-fx-background-color: #2c3e50;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="TelaZController">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>
    <children>
        <Label text="Bem-vindo ao Painel de Controle!" textFill="WHITE">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>
        
        <Label fx:id="labelStatus" text="Instalador: Carregando..." textFill="#bdc3c7">
            <font>
                <Font size="14.0" />
            </font>
        </Label>
          <Button mnemonicParsing="false" onAction="#verificarTelemetria" prefHeight="45.0" prefWidth="280.0" style="-fx-background-color: #969696; -fx-text-fill: white;" text="Ver lista de Sensores" />
                  
                <Button mnemonicParsing="false" onAction="#realizarInstalacao" prefHeight="45.0" prefWidth="280.0" style="-fx-background-color: #919191; -fx-text-fill: white;" text="Cadastrar novo veículo / Sensor" />
    </children>
</VBox>
